<%- include('../partials/head') %>
<div class="ballot-head"><div class="bar"></div><div class="hairlines"></div></div>
<p class="eyebrow">Credential delivery</p>
<h1>Credentials emailed</h1>
<div class="stat-row">
  <div class="stat"><div class="n"><%= sent %></div><div class="l">Emails sent</div></div>
  <div class="stat"><div class="n"><%= failures.length %></div><div class="l">Failures</div></div>
  <div class="stat"><div class="n"><%= paper.length %></div><div class="l">Need paper ballots</div></div>
</div>
<% if (failures.length) { %>
<div class="notice warn"><strong>Delivery failures — follow up or reissue:</strong>
<ul><% failures.forEach(function (f) { %><li><%= f %></li><% }) %></ul></div>
<% } %>
<% if (paper.length) { %>
<h2>Alternative method required</h2>
<ul><% paper.forEach(function (m) { %><li><%= m.name %></li><% }) %></ul>
<% } %>
<a class="btn primary" href="/admin/elections/<%= e.id %>">Continue</a>
<%- include('../partials/foot') %>
