<%- include('../partials/head') %>
<div class="ballot-head"><div class="bar"></div><div class="hairlines"></div></div>
<p class="eyebrow">Accounts</p>
<h1>Committee &amp; observer accounts</h1>
<p class="sub">Every candidate has the right to an observer. Observer accounts are read-only: turnout, configuration, audit log, results — never ballots, never credentials.</p>
<h2>Create account</h2>
<form method="post" action="/admin/users" style="max-width:460px">
  <label>Display name</label><input type="text" name="display_name" required placeholder="Observer for Candidate Smith">
  <label>Username</label><input type="text" name="username" required>
  <label>Password (10+ characters)</label><input type="text" name="password" minlength="10" required>
  <label>Role</label>
  <select name="role"><option value="observer">Observer (read-only)</option><option value="admin">Administrator</option></select>
  <button class="btn" type="submit">Create</button>
</form>
<h2>Existing accounts</h2>
<table>
<tr><th>Name</th><th>Username</th><th>Role</th><th>Created</th></tr>
<% users.forEach(function (u) { %>
<tr><td><%= u.display_name %></td><td><%= u.username %></td><td><%= u.role %></td><td><%= u.created_at %></td></tr>
<% }) %>
</table>
<%- include('../partials/foot') %>
