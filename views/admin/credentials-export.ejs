<%- include('../partials/head') %>
<div class="ballot-head"><div class="bar"></div><div class="hairlines"></div></div>
<p class="eyebrow">Shown exactly once — never retrievable again</p>
<h1><%= title %></h1>
<div class="notice warn">
  <strong>Handle like live ballots.</strong> The system stores only hashes of these credentials.
  Deliver each credential to its member (mail-merge email or printed letter), then destroy this
  copy. Candidate observers may watch this preparation but must not see individual credentials
  next to names for longer than delivery requires.
</div>
<p>Voting link to include: <span class="mono"><%= voteUrl %></span></p>
<table>
<tr><th>Member</th><th>Email</th><th>Credential (one-time)</th></tr>
<% issued.forEach(function (row) { %>
<tr><td><%= row.member.name %></td><td><%= row.member.email || '—' %></td><td class="mono"><%= row.credential %></td></tr>
<% }) %>
</table>
<% if (paper && paper.length) { %>
<h2>Alternative method required</h2>
<p>These eligible members have no email or are flagged for paper — provide them a paper ballot:</p>
<ul><% paper.forEach(function (m) { %><li><%= m.name %></li><% }) %></ul>
<% } %>
<a class="btn primary" href="/admin/elections/<%= e.id %>">Done — I have delivered/secured these</a>
<%- include('../partials/foot') %>
