<%- include('partials/head') %>
<div class="ballot-head"><div class="bar"></div><div class="hairlines"></div></div>
<p class="eyebrow">Official secret ballot<%= election.is_test ? ' — practice run, results do not count' : '' %></p>
<h1><%= election.title %></h1>
<% if (election.is_test) { %><p><span class="tag test">Test election</span></p><% } %>

<form method="post" action="/vote/cast" id="ballotForm">
  <input type="hidden" name="credential" value="<%= credential %>">
  <div class="ballot">
    <% races.forEach(function (race) { %>
      <div class="race" data-seats="<%= race.seats %>" data-race="<%= race.id %>">
        <h3><%= race.title %></h3>
        <p class="instr">
          <% if (race.seats === 1) { %>Vote for one.<% } else { %>Vote for up to <%= race.seats %>.<% } %>
          You may also leave this blank.
        </p>
        <% race.candidates.forEach(function (c) { %>
          <div class="cand">
            <input type="<%= race.seats === 1 ? 'radio' : 'checkbox' %>"
                   id="c<%= c.id %>" name="race_<%= race.id %>" value="<%= c.id %>">
            <label for="c<%= c.id %>"><%= c.name %></label>
          </div>
        <% }) %>
      </div>
    <% }) %>
  </div>

  <div class="notice warn" id="overvoteWarn" style="display:none">
    You have selected more choices than allowed in one of the races above. Remove a selection to continue.
  </div>

  <button class="btn primary" type="submit">Cast ballot — final</button>
  <p class="sub" style="font-size:13.5px">Casting is final and your credential will be spent. Your selections are
  encrypted immediately and are not shown back to you afterward, so that no one can pressure you to prove how you voted.</p>
</form>

<script>
(function () {
  var form = document.getElementById('ballotForm');
  var warn = document.getElementById('overvoteWarn');
  function check() {
    var bad = false;
    document.querySelectorAll('.race').forEach(function (r) {
      var seats = Number(r.dataset.seats);
      var n = r.querySelectorAll('input:checked').length;
      if (n > seats) bad = true;
    });
    warn.style.display = bad ? '' : 'none';
    return !bad;
  }
  form.addEventListener('change', check);
  form.addEventListener('submit', function (e) { if (!check()) e.preventDefault(); });
})();
</script>
<%- include('partials/foot') %>
